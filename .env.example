# aiproxy — все переменные окружения
# Скопируйте этот файл в .env и отредактируйте под свою среду.

# Сервер
COPILOT2API_HOST=127.0.0.1      # хост (по умолчанию 127.0.0.1)
COPILOT2API_PORT=7777            # порт (по умолчанию 7777)

# Хранилище токенов OAuth
COPILOT2API_TOKEN_DIR=~/.config/copilot2api

# Логирование
COPILOT2API_DEBUG=false          # true для отладочных логов

# linguafranca (конвертация Responses↔Messages)
LINGUAFRANCA_BRIDGE=scripts/linguafranca_bridge.py

# AmpCode локальный режим
AMP_THREADS_DIR=~/.config/copilot2api/threads
